# Variables de entorno para auto-aprendizaje semanal del RAG

# Zoho SalesIQ (REQUERIDO para extraer conversaciones)
# Cómo obtenerlo: https://www.zoho.com/salesiq/help/developer-section/oauth-api.html
ZOHO_SALESIQ_PORTAL_ID=tu_portal_id_aqui
ZOHO_SALESIQ_ACCESS_TOKEN=tu_oauth_token_aqui

# Backend RAG (default: Render)
RAG_BACKEND_URL=https://kaven-bot.onrender.com

# Token de administración RAG (OPCIONAL - solo si configuraste RAG_ADMIN_TOKEN en Render)
RAG_ADMIN_TOKEN=

# Notificaciones (OPCIONAL - para recibir resumen semanal)
NOTIFICATION_EMAIL=tu@email.com
